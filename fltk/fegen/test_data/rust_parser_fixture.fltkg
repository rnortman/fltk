// Fixture grammar for Rust parser generator tests.
// Covers: literal, regex, quantifiers (+, ?, *), WS_REQUIRED separator,
//         sub-expression, union label, suppress, include,
//         direct + indirect left recursion, multibyte literal + regex.

// A number (one or more digits)
num := value:/[0-9]+/ ;

// A name (one or more lowercase letters)
name := value:/[a-z]+/ ;

// An atom: either a number or a name, or a parenthesised expression
atom := num:num | name:name ;

// Parenthesised expression (sub-expression with WS_ALLOWED inner separators)
paren_expr := %"(" , inner:atom , %")" ;

// A statement requiring whitespace between lhs and operator and rhs
stmt := lhs:atom : "=" : rhs:atom ;

// One or more atoms
items := item:atom+ ;

// Zero or one atom
opt_item := item:atom? ;

// Zero or more atoms
zero_items := item:atom* ;

// Direct left recursion: expr := expr "+" rhs | atom
// Tests that the packrat memoizer handles left-recursive grammars correctly.
expr := lhs:expr . "+" . rhs:atom | atom:atom ;

// Indirect left recursion: lval and rval are mutually left-recursive via each other.
// lval can start with rval (indirect), rval can start with lval (indirect).
lval := inner:rval . "!" | base:name ;
rval := inner:lval . "?" | base:num ;

// Multibyte literal: arrow operator (→, U+2192, 3 UTF-8 bytes).
// Span offsets must be codepoint-indexed, not byte-indexed.
arrow := %"→" . target:name ;

// Multibyte regex: matches one or more characters in the range U+00C0..U+00FF
// (Latin Extended characters, all multi-byte in UTF-8).
latin_word := value:/[À-ÿ]+/ ;

// $-included unlabeled literal: "tag" span appears as an unlabeled child.
tagged := $"tag" . value:/[a-z]+/ ;

// Union label: the same label "item" applies to two different types (num node, name node,
// or a bare regex span).  The third alternative exercises the union-span arm
// (cst::ValChild::Span) of the append path (design §2.6B).
val := item:num | item:name | item:/[!@#$]+/ ;

// Rule with a leading WS_ALLOWED separator (initial_sep).
// Tests that initial_sep is handled correctly in the Rust generator.
leading_ws := , num:num ;

// Sub-expression with WS_ALLOWED separator between the alternatives inside.
// Tests that separators inside sub-expressions are generated correctly in Rust.
grouped := %"(" , (left:num | left:name) , %")" ;

// Recursion through a sub-expression: the inner sub-expression returns the
// parent node type (inline_to_parent=True path).
// Tests the extend_children path through recursive sub-expression inlining.
rec_via_sub := (inner:rec_via_sub . "+" | inner:atom) . suffix:name ;

// Right-recursive nesting: apply depth proportional to input nesting (depth-limit tests).
nest := %"(" . inner:nest . %")" | leaf:num ;

// Left recursion whose growth step descends into nesting: a depth-rejected growth
// iteration stalls grow_seed, which returns the seed — the Some-with-flag shape (§2).
nest_sum := lhs:nest_sum . "+" . rhs:nest | first:nest ;

// ---------------------------------------------------------------------------
// Portable-but-tricky regex parity cases (design §5.6)
// Each rule exercises a regex construct verified portable on both Python re and
// Rust regex-automata.  Every pattern is non-nullable (matches ≥1 character) so
// it is safe in quantified rules.
// ---------------------------------------------------------------------------

// ASCII \d (digit shorthand, portable for ASCII; non-ASCII residual documented)
digit_seq := value:/\d+/ ;

// ASCII \w (word char shorthand, ASCII-portable)
word_seq := value:/\w+/ ;

// ASCII \s (whitespace shorthand, ASCII-portable) — used as trivia-aware rule
// Note: \s matches at least one char, non-nullable.
ws_seq := value:/\s+/ ;

// Bounded quantifier {m,n} (portable on both engines)
three_to_five_digits := value:/[0-9]{3,5}/ ;

// Exact-count bounded quantifier {n}
exactly_two_digits := value:/[0-9]{2}/ ;

// Escaped metacharacters (literal dot, star, plus)
escaped_metas := value:/\.\*\+/ ;

// Character range with non-ASCII (Latin Extended, as in latin_word but with ranges)
latin_range := value:/[À-Ö]+/ ;

// Non-capturing group with alternation
nc_group_alt := value:/(?:ab|cd)+/ ;

// ASCII case-insensitive flag (?i) — portable as syntax; non-ASCII case-fold residual documented
case_insensitive := value:/(?i)[a-z]+/ ;

// Anchored pattern: ^ and $ (line anchors, portable)
// Must consume entire input for parity tests to work; use non-empty prefix
anchored_word := value:/^[a-z]+$/ ;
